# ── Copy this file to .env and fill in your values ────────────────────────────

# PostgreSQL — native local installation
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/elevate_ai

# ChromaDB — path to the persistent vector store directory
CHROMA_DB_PATH=./chroma_db

# Ollama — local native OS app (no Docker)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# Sentence-Transformers fallback (used by ingest script if Ollama embed unavailable)
EMBED_MODEL_NAME=all-MiniLM-L6-v2

# JWT auth
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Admin credentials for the upload panel (Phase 5)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
