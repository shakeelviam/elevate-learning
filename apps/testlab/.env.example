# ── Database ──────────────────────────────────────────────────────────────────
# Same PostgreSQL instance as the FastAPI backend (separate tables prefixed tl_)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/elevate_ai

# ── Admin credentials (never stored in DB) ───────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# Used to sign the admin browser session cookie — generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=replace_with_32_byte_hex_string

# ── Cookie security ───────────────────────────────────────────────────────────
# Set to "false" when serving over plain HTTP (no SSL) e.g. IP-only deployment.
# Remove this line (or set to "true") once HTTPS is configured.
COOKIE_SECURE=false

# ── FastAPI integration ───────────────────────────────────────────────────────
# URL of the FastAPI AI backend
FASTAPI_URL=http://localhost:8000

# Must match SECRET_KEY in the FastAPI backend .env
FASTAPI_JWT_SECRET=insecure-dev-key-change-in-production

# ── Next.js public vars ───────────────────────────────────────────────────────
NEXT_PUBLIC_TEST_LAB_API_URL=http://localhost:8000

# ── Production: set this to the testlab subdomain ────────────────────────────
# NEXTAUTH_URL=https://testlab.yourdomain.com
